{
  "name": "journal",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:editor": "esbuild src/client/markdown-editor.ts --bundle --format=esm --outfile=public/markdown-editor.mjs --watch",
    "dev:worker": "wrangler dev",
    "dev:css": "tailwindcss -i ./src/styles/app.css -o ./public/app.css --watch",
    "build:editor": "esbuild src/client/markdown-editor.ts --bundle --format=esm --outfile=public/markdown-editor.mjs",
    "build:css": "tailwindcss -i ./src/styles/app.css -o ./public/app.css",
    "generate:prompts": "node ./scripts/generate-prompts.mjs",
    "deploy": "npm run build:css && npm run build:editor && wrangler deploy",
    "cf-typegen": "wrangler types",
    "check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "basecoat-css": "^0.3.11",
    "hono": "^4.12.14",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@cloudflare/workers-types": "^4.20260422.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/markdown-it": "^14.1.2",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  }
}
